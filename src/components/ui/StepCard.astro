---
export interface Props {
	number: number | string;
	title: string;
	description: string;
}

const { number, title, description } = Astro.props;
---

<div
	class="bg-white rounded-3xl p-8 md:p-10 text-center shadow-xl hover:shadow-2xl hover:-translate-y-2 transition-all duration-300">
	<div
		class="w-16 h-16 md:w-20 md:h-20 bg-linear-to-br from-orange-600 to-orange-500 rounded-full flex items-center justify-center mx-auto mb-5 shadow-lg">
		<span class="text-white text-3xl md:text-4xl font-black">{number}</span>
	</div>
	<h3 class="text-orange-600 text-xl md:text-2xl font-bold mb-3 leading-snug">
		{title}
	</h3>
	<p
		class="text-gray-600 text-sm md:text-base leading-relaxed"
		set:html={description}
	/>
</div>
