---
import { Image } from "astro:assets";

export interface Props {
	href: string;
	src: string;
	alt: string;
	label: string;
}

const { href, src, alt, label } = Astro.props;
---

<a
	href={href}
	target="_blank"
	class="inline-flex items-center justify-center gap-4 hover:scale-110 transition-transform duration-300"
	rel="noopener noreferrer"
	aria-label={label}>
	<Image
		src={src}
		alt={alt}
		width={200}
		height={60}
		class="h-14 md:h-16 lg:h-20 w-auto"
	/>
</a>
